;   param=value ; assign values to parameters

config_version=5

[application]

config/name="gd-ball-sim"
run/main_scene="uid://dr1yql5ksl0e3"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/resizable=false

[physics]

